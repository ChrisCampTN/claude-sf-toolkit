#!/bin/bash
# claude-sf-toolkit pre-commit hook
# 1. Run plugin structural validation (if in plugin repo)
# 2. Run resolve-cache.js unit tests (if in plugin repo)
# 3. Run Prettier via lint-staged (if configured)
# 4. Block force-app/ commits on main branch

# Plugin validation (only runs in the plugin repo itself, not consuming projects)
if [ -f "scripts/validate-plugin.js" ]; then
  echo "Running plugin validation..."
  if ! node scripts/validate-plugin.js; then
    echo "ERROR: Plugin validation failed. Fix issues before committing."
    exit 1
  fi
  echo ""
fi

if [ -f "scripts/test-resolve-cache.js" ]; then
  echo "Running resolve-cache tests..."
  if ! node scripts/test-resolve-cache.js; then
    echo "ERROR: resolve-cache.js tests failed. Fix issues before committing."
    exit 1
  fi
  echo ""
fi

# Run lint-staged if available
if command -v npx &> /dev/null && [ -f "package.json" ]; then
  npx lint-staged 2>/dev/null
fi

# Block force-app/ commits on main
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  STAGED_FORCEAPP=$(git diff --cached --name-only | grep "^force-app/" || true)
  if [ -n "$STAGED_FORCEAPP" ] && [ -z "$ALLOW_FORCEAPP_ON_MAIN" ]; then
    echo "ERROR: force-app/ changes must go to WI branches via /devops-commit"
    echo "Staged force-app files:"
    echo "$STAGED_FORCEAPP"
    echo ""
    echo "Override with: ALLOW_FORCEAPP_ON_MAIN=1 git commit ..."
    exit 1
  fi
fi
